# Copy to .env and fill in. .env is gitignored — never commit real values.

# Philips/Versuni account email used in the official HomeID/Air+ app.
PHILIPS_EMAIL=you@example.com

# CTN prefix used to auto-pick the device (the fan should report CX3550/01).
PHILIPS_DEVICE_CTN=CX3550

# --- Region (defaults are EU / Germany; only change if your account is elsewhere) ---
# PHILIPS_PLATFORM_REST_URL=prod.eu-da.iot.versuni.com
# PHILIPS_TENANT=da
# PHILIPS_MQTT_HOST=ats.prod.eu-da.iot.versuni.com

# --- Debug only ---
# PHILIPS_MQTT_CLIENT_ID=
